# Telegram
BOT_TOKEN=123456:ABCDEF

# Optional: Telegram webhook secret token header (recommended).
# Telegram will send it in header `X-Telegram-Bot-Api-Secret-Token`.
TELEGRAM_SECRET_TOKEN=change_me

# Hugging Face Space for img2img (free/public by default)
HF_SPACE_ID=diffusers/unofficial-SDXL-Turbo-i2i-t2i

# Optional: HF token (only needed if the Space requires it)
HF_TOKEN=

# Generation defaults
GEN_STRENGTH=0.65
GEN_STEPS=2
GEN_TIMEOUT_SEC=180
